# Copy this file to `.env` in the project root and fill in values from the Supabase dashboard
# (Settings → API: Project URL and anon public key). Restart `npm run dev` after changes.

# Supabase project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon (public) key — safe for browser use; never commit the service role key here
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: slightly more verbose client logging (console only)
# VITE_ENABLE_APP_LOGGING=true

# Optional: Sales Daily Sheets import — Storage bucket and key prefix (defaults: sales-daily-sheets / incoming/)
# VITE_SALES_DAILY_SHEETS_BUCKET=sales-daily-sheets
# VITE_SALES_DAILY_SHEETS_PATH_PREFIX=incoming/
#
# Server-side (Supabase SQL / Edge — not Vite): see DEPLOY.md § Sales Daily Sheets import.
# - app.sales_daily_import_edge_url, app.internal_import_secret on the database
# - Edge secret INTERNAL_IMPORT_SECRET and deploy supabase/functions/sales-daily-sheets-import
